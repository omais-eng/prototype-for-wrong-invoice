# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airp:airp_pass@localhost:5432/airp_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Mock ERP ──────────────────────────────────────────────────────────────────
MOCK_ERP_URL=http://localhost:8001

# ─── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Leave empty to run in template/mock mode (no API calls made)
ANTHROPIC_API_KEY=

# ─── Email / SMTP ──────────────────────────────────────────────────────────────
# Leave empty to run in console-log mock mode
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=invoices@yourcompany.com

# ─── Email / IMAP (inbox polling) ──────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_USER=invoices@yourcompany.com
IMAP_PASS=your-app-password

# ─── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
